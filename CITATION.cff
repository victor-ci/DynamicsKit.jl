    given-names: Victor Chukwuma
    affiliation: "Riga Technical University"
    orcid: "https://orcid.org/0009-0003-3839-5052"
license: MIT
doi: 10.5281/zenodo.21327845
repository-code: "https://github.com/victor-ci/DynamicsKit.jl"
url: "https://github.com/victor-ci/DynamicsKit.jl"
identifiers:
